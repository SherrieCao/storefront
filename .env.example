# Copy to .env and fill in. .env is gitignored — never commit real keys.
# The pipeline runs end-to-end offline with stubbed providers when keys are absent.

ANTHROPIC_API_KEY=        # Claude — per-shot prompt craft, structured edit-plan JSON, the critic reviewers
GEMINI_API_KEY=           # Gemini — the multimodal Concept + Director brain, and the per-shot video judge
FAL_KEY=                  # fal.ai — Nano Banana keyframes, Seedance shots, ElevenLabs voice, photo enhance
GOOGLE_PLACES_API_KEY=    # Google Places (New) — real customer reviews to anchor the concept (optional)
YELP_API_KEY=             # optional secondary review source (dormant by default)
